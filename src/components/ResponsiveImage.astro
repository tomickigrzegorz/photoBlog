---
interface Props {
  folder: string;
  filename: string;
  alt?: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const { folder, filename, alt = '', width = 1200, height = 800, class: className, loading = 'lazy' } = Astro.props;

const basePath = `/images/${folder}`;
const webpFilename = filename.replace(/\.(jpg|JPG)$/, '.webp');

const fallback = `${basePath}/1200/${filename}`;
const webpSrcset = [576, 768, 992, 1200]
  .map((size) => `${basePath}/${size}/${webpFilename} ${size}w`)
  .join(', ');
---

<picture>
  <source
    type="image/webp"
    srcset={webpSrcset}
    sizes="(max-width: 576px) 576px, (max-width: 768px) 768px, (max-width: 992px) 992px, 1200px"
  />
  <img
    src={fallback}
    alt={alt}
    loading={loading}
    class={className || 'zooom'}
    width={width}
    height={height}
  />
</picture>
<noscript>
  <img src={fallback} alt={alt} loading={loading} width={width} height={height} />
</noscript>
